{
  "name": "easy-planning-poker",
  "version": "1.0.0",
  "description": "Scrum Planning Poker App - Full Stack Monorepo Manager",
  "main": "index.js",
  "scripts": {
    "bootstrap": "npm run install:backend && npm run install:frontend",
    "install:backend": "npm install --prefix backend",
    "install:frontend": "npm install --prefix frontend",
    "start": "pm2 start ecosystem.config.js",
    "stop": "pm2 stop ecosystem.config.js",
    "status": "pm2 status",
    "logs": "pm2 logs",
    "dev": "pm2 start ecosystem.config.js --no-daemon"
  },
  "dependencies": {
    "pm2": "^5.3.1"
  }
}
